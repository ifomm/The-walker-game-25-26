from kivy.app import App
from kivy.uix.widget import Widget
from kivy.uix.button import Button
from kivy.uix.label import Label
from kivy.uix.boxlayout import BoxLayout
from kivy.uix.popup import Popup
from kivy.uix.textinput import TextInput
from kivy.graphics import Color, Rectangle, Ellipse
from kivy.core.window import Window
import random

class QuestionPopup(Popup):
    def __init__(self, question, correct_answer, on_correct, on_wrong, **kwargs):
        super().__init__(**kwargs)
        self.correct_answer = correct_answer
        self.on_correct = on_correct
        self.on_wrong = on_wrong
        self.title = 'Вопрос'
        self.size_hint = (0.8, 0.5)
        self.auto_dismiss = False
        
        layout = BoxLayout(orientation='vertical', padding=10, spacing=10)
        
        # Вопрос
        self.question_label = Label(text=question, font_size=16, size_hint=(1, 0.4))
        layout.add_widget(self.question_label)
        
        # Поле для ответа
        self.answer_input = TextInput(hint_text='Введите ответ', multiline=False, font_size=14)
        layout.add_widget(self.answer_input)
        
        # Кнопка ответить (без кнопки отмена)
        submit_btn = Button(text='Ответить', font_size=16, size_hint=(1, 0.2))
        submit_btn.bind(on_press=self.check_answer)
        layout.add_widget(submit_btn)
        
        self.content = layout
    
    def check_answer(self, instance):
        user_answer = self.answer_input.text.strip()
        try:
            if self.correct_answer.replace('.', '').replace('-', '').isdigit() or \
               (self.correct_answer[0] == '-' and self.correct_answer[1:].replace('.', '').isdigit()):
                user_num = float(user_answer)
                correct_num = float(self.correct_answer)
                if abs(user_num - correct_num) < 0.0001:
                    self.dismiss()
                    self.on_correct()
                else:
                    self.dismiss()
                    self.on_wrong()
            else:
                if user_answer.lower() == self.correct_answer.lower():
                    self.dismiss()
                    self.on_correct()
                else:
                    self.dismiss()
                    self.on_wrong()
        except ValueError:
            if user_answer.lower() == self.correct_answer.lower():
                self.dismiss()
                self.on_correct()
            else:
                self.dismiss()
                self.on_wrong()

class GameBoard(Widget):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.cell_size = 60
        self.board_size = 8
        self.player_pos = [0, 0]
        self.target_pos = [7, 7]
        self.obstacles = []
        self.question_cells = []
        
        # Банк вопросов
        self.questions_bank = {
            # Математика
            "Сколько будет 15 * 8?": "120",
            "Чему равен квадратный корень из 144?": "12",
            "Решите уравнение: 3x + 5 = 20": "5",
            "Вычислите: 2^6": "64",
            "Сколько градусов в прямом угле?": "90",
            "Чему равно 12 * 12?": "144",
            "Сколько будет 7 * 8?": "56",
            "Найдите 20% от 50": "10",
            "Сколько будет 25 * 4?": "100",
            "Чему равен корень из 81?": "9",
            
            # Физика
            "Формула закона Ома? (введите формулу)": "I=U/R",
            "Ускорение свободного падения на Земле (м/с²)?": "9.8",
            "Сколько секунд в одной минуте?": "60",
            "Что тяжелее: 1 кг пуха или 1 кг железа?": "одинаково",
            "Какая планета ближе всех к Солнцу?": "Меркурий",
            "Сколько минут в одном часе?": "60",
            "Какая сила измеряется в Ньютонах?": "сила",
            "Какой газ выделяют растения при фотосинтезе?": "кислород",
            "Чему равна скорость света (км/с)?": "300000",
        }
        
        self.current_questions = {}
        self.generate_obstacles()
        self.generate_question_cells()
        self.waiting_for_answer = False
        self.pending_move = None
        self.bind(pos=self.update_canvas, size=self.update_canvas)
    
    def generate_obstacles(self):
        self.obstacles = []
        num_obstacles = 12
        for _ in range(num_obstacles):
            x = random.randint(0, self.board_size - 1)
            y = random.randint(0, self.board_size - 1)
            if ([x, y] != self.player_pos and 
                [x, y] != self.target_pos and
                [x, y] not in self.obstacles):
                self.obstacles.append([x, y])
    
    def generate_question_cells(self):
        # Создаем новые случайные клетки с вопросами
        self.question_cells = []
        self.current_questions = {}
        
        available_questions = list(self.questions_bank.items())
        random.shuffle(available_questions)
        
        num_questions = random.randint(8, 12)
        attempts = 0
        
        while len(self.question_cells) < num_questions and attempts < 100:
            x = random.randint(0, self.board_size - 1)
            y = random.randint(0, self.board_size - 1)
            
            if ([x, y] != self.player_pos and 
                [x, y] != self.target_pos and 
                [x, y] not in self.obstacles and
                [x, y] not in self.question_cells):
                
                if len(available_questions) > 0:
                    question, answer = available_questions.pop(0)
                    self.question_cells.append([x, y])
                    self.current_questions[(x, y)] = (question, answer)
            
            attempts += 1
        
        if len(self.question_cells) < 5:
            for i in range(5 - len(self.question_cells)):
                x = random.randint(0, self.board_size - 1)
                y = random.randint(0, self.board_size - 1)
                if ([x, y] != self.player_pos and 
                    [x, y] != self.target_pos and 
                    [x, y] not in self.obstacles and
                    [x, y] not in self.question_cells):
                    question, answer = list(self.questions_bank.items())[i % len(self.questions_bank)]
                    self.question_cells.append([x, y])
                    self.current_questions[(x, y)] = (question, answer)
    
    def update_canvas(self, *args):
        self.canvas.clear()
        with self.canvas:
            # Рисуем сетку - все клетки одного цвета, кроме препятствий и цели
            for x in range(self.board_size):
                for y in range(self.board_size):
                    # Цвет клетки (все обычные клетки одинаковые)
                    if [x, y] in self.obstacles:
                        Color(0.5, 0.2, 0.2, 1)  # Бордовый для препятствий
                    elif [x, y] == self.target_pos:
                        Color(0.2, 0.7, 0.2, 1)  # Зеленый для цели
                    else:
                        Color(0.9, 0.9, 0.9, 1)  # Светло-серый для всех остальных клеток
                    
                    Rectangle(pos=(
                        self.x + x * self.cell_size,
                        self.y + y * self.cell_size
                    ), size=(self.cell_size, self.cell_size))
                    
                    # Рисуем границы клеток
                    Color(0.3, 0.3, 0.3, 1)
                    Rectangle(pos=(
                        self.x + x * self.cell_size,
                        self.y + y * self.cell_size
                    ), size=(self.cell_size, 1))
                    Rectangle(pos=(
                        self.x + x * self.cell_size,
                        self.y + y * self.cell_size
                    ), size=(1, self.cell_size))
            
            # Рисуем игрока (круглый)
            Color(0.2, 0.4, 0.8, 1)
            Ellipse(pos=(
                self.x + self.player_pos[0] * self.cell_size + 5,
                self.y + self.player_pos[1] * self.cell_size + 5
            ), size=(self.cell_size - 10, self.cell_size - 10))
    
    def ask_question(self, pos, on_correct, on_wrong):
        if tuple(pos) in self.current_questions:
            question, answer = self.current_questions[tuple(pos)]
            popup = QuestionPopup(question, answer, on_correct, on_wrong)
            popup.open()
            return True
        return False
    
    def move_player(self, dx, dy, on_question_correct=None, on_question_wrong=None):
        if self.waiting_for_answer:
            return False
            
        new_x = self.player_pos[0] + dx
        new_y = self.player_pos[1] + dy
        
        if 0 <= new_x < self.board_size and 0 <= new_y < self.board_size:
            if [new_x, new_y] in self.obstacles:
                return False
            
            if [new_x, new_y] in self.question_cells:
                self.waiting_for_answer = True
                self.pending_move = [new_x, new_y]
                
                def on_correct():
                    self.player_pos = [new_x, new_y]
                    self.waiting_for_answer = False
                    self.update_canvas()
                    if on_question_correct:
                        on_question_correct()
                    if self.player_pos == self.target_pos:
                        on_question_correct(True)
                
                def on_wrong():
                    self.player_pos = [0, 0]
                    self.waiting_for_answer = False
                    self.update_canvas()
                    if on_question_wrong:
                        on_question_wrong()
                
                self.ask_question([new_x, new_y], on_correct, on_wrong)
                return False
            else:
                self.player_pos = [new_x, new_y]
                self.update_canvas()
                
                if self.player_pos == self.target_pos:
                    if on_question_correct:
                        on_question_correct(True)
                return True
        return False

class WalkGame(App):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.moves_count = 0
        self.wrong_answers = 0
        
    def build(self):
        main_layout = BoxLayout(orientation='vertical', padding=10, spacing=10)
        
        control_layout = BoxLayout(orientation='horizontal', size_hint=(1, 0.2))
        
        buttons_layout = BoxLayout(orientation='vertical', size_hint=(0.3, 1))
        
        up_btn = Button(text='↑', font_size=20)
        up_btn.bind(on_press=lambda x: self.move(0, 1))
        
        middle_layout = BoxLayout(orientation='horizontal', size_hint=(1, 0.3))
        left_btn = Button(text='←', font_size=20)
        right_btn = Button(text='→', font_size=20)
        left_btn.bind(on_press=lambda x: self.move(-1, 0))
        right_btn.bind(on_press=lambda x: self.move(1, 0))
        
        down_btn = Button(text='↓', font_size=20)
        down_btn.bind(on_press=lambda x: self.move(0, -1))
        
        middle_layout.add_widget(left_btn)
        middle_layout.add_widget(right_btn)
        
        buttons_layout.add_widget(up_btn)
        buttons_layout.add_widget(middle_layout)
        buttons_layout.add_widget(down_btn)
        
        info_layout = BoxLayout(orientation='vertical', size_hint=(0.7, 1), spacing=5)
        
        self.moves_label = Label(text='Ходы: 0', font_size=16)
        self.wrong_label = Label(text='Ошибок: 0', font_size=14, color=(0.8, 0.2, 0.2, 1))
        self.status_label = Label(text='Дойди до зеленой клетки!\nИзбегай бордовых препятствий', font_size=12)
        
        info_layout.add_widget(self.moves_label)
        info_layout.add_widget(self.wrong_label)
        info_layout.add_widget(self.status_label)
        
        control_layout.add_widget(buttons_layout)
        control_layout.add_widget(info_layout)
        
        self.game_board = GameBoard(size_hint=(1, 0.8))
        
        main_layout.add_widget(control_layout)
        main_layout.add_widget(self.game_board)
        
        return main_layout
    
    def move(self, dx, dy):
        def on_move_success(is_victory=False):
            self.moves_count += 1
            self.moves_label.text = f'Ходы: {self.moves_count}'
            
            if is_victory:
                self.status_label.text = f'Победа! Достигнуто за {self.moves_count} ходов!'
                self.show_victory_popup()
        
        def on_wrong_answer():
            self.wrong_answers += 1
            self.wrong_label.text = f'Ошибок: {self.wrong_answers}'
        
            self.moves_count += 1
         
        
        self.game_board.move_player(dx, dy, on_move_success, on_wrong_answer)
    
    def show_victory_popup(self):
        popup = Popup(title='Поздравляем!', 
                      size_hint=(0.6, 0.4),
                      auto_dismiss=False)
        
        layout = BoxLayout(orientation='vertical', padding=10, spacing=10)
        message = Label(text=f'Вы выиграли!\n\nХодов: {self.moves_count}\nОшибок: {self.wrong_answers}\n\nОтличная работа!', 
                       font_size=16, halign='center')
        restart_btn = Button(text='Играть снова', size_hint=(1, 0.3))
        restart_btn.bind(on_press=lambda x: self.restart_game(popup))
        
        layout.add_widget(message)
        layout.add_widget(restart_btn)
        popup.content = layout
        popup.open()
    
    def restart_game(self, popup=None):
        if popup:
            popup.dismiss()
        self.root.clear_widgets()
        self.__init__()
        self.root.add_widget(self.build())

if __name__ == '__main__':
    WalkGame().run()
