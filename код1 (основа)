from kivy.app import App
from kivy.uix.boxlayout import BoxLayout
from kivy.uix.button import Button
from kivy.uix.label import Label
from kivy.uix.textinput import TextInput
from kivy.uix.popup import Popup
from kivy.uix.widget import Widget
from kivy.graphics import Color, Rectangle, Ellipse, Triangle
from kivy.core.window import Window
from kivy.clock import Clock
from kivy.properties import NumericProperty, ListProperty, StringProperty
import random

class GameWidget(Widget):
    player_pos = ListProperty([100, 100])
    player_size = NumericProperty(40)
    player_color = ListProperty([1, 0, 0])  # Красный по умолчанию
    player_shape = StringProperty('circle')  # circle, square, triangle
    
    obstacle_pos = ListProperty([300, 100, 400, 200])  # x1, y1, x2, y2
    obstacle_color = ListProperty([0, 0, 1])  # Синий по умолчанию
    
    def __init__(self, **kwargs):
        super(GameWidget, self).__init__(**kwargs)
        self._keyboard = Window.request_keyboard(self._keyboard_closed, self)
        self._keyboard.bind(on_key_down=self._on_keyboard_down)
        # Первоначальная отрисовка
        Clock.schedule_once(self.draw_all, 0.1)
        
    def _keyboard_closed(self):
        if self._keyboard:
            self._keyboard.unbind(on_key_down=self._on_keyboard_down)
            self._keyboard = None
        
    def _on_keyboard_down(self, keyboard, keycode, text, modifiers):
        # Управление игроком
        step = 10
        new_x, new_y = self.player_pos
        
        if keycode[1] == 'w':  # Вверх
            new_y += step
        elif keycode[1] == 's':  # Вниз
            new_y -= step
        elif keycode[1] == 'a':  # Влево
            new_x -= step
        elif keycode[1] == 'd':  # Вправо
            new_x += step
            
        # Проверка границ экрана
        new_x = max(self.player_size/2, min(self.width - self.player_size/2, new_x))
        new_y = max(self.player_size/2, min(self.height - self.player_size/2, new_y))
        
        self.player_pos = [new_x, new_y]
        self.draw_all()
        
        return True
    
    def draw_all(self, *args):
        """Полная перерисовка всех элементов"""
        self.canvas.clear()
        self.canvas.after.clear()
        
        with self.canvas:
            # Отрисовка препятствия
            Color(*self.obstacle_color)
            Rectangle(pos=(self.obstacle_pos[0], self.obstacle_pos[1]),
                     size=(self.obstacle_pos[2] - self.obstacle_pos[0], 
                          self.obstacle_pos[3] - self.obstacle_pos[1]))
        
        with self.canvas.after:
            # Отрисовка игрока
            Color(*self.player_color)
            if self.player_shape == 'circle':
                Ellipse(pos=(self.player_pos[0] - self.player_size/2, 
                           self.player_pos[1] - self.player_size/2),
                       size=(self.player_size, self.player_size))
            elif self.player_shape == 'square':
                Rectangle(pos=(self.player_pos[0] - self.player_size/2, 
                              self.player_pos[1] - self.player_size/2),
                         size=(self.player_size, self.player_size))
            elif self.player_shape == 'triangle':
                points = [
                    self.player_pos[0], self.player_pos[1] + self.player_size/2,  # Верх
                    self.player_pos[0] - self.player_size/2, self.player_pos[1] - self.player_size/2,  # Левый низ
                    self.player_pos[0] + self.player_size/2, self.player_pos[1] - self.player_size/2   # Правый низ
                ]
                Triangle(points=points)
    
    def change_theme(self, theme):
        """Изменение внешнего вида игры в зависимости от темы"""
        if theme == "quantum":
            self.player_color = [0.5, 0, 0.5]  # Фиолетовый
            self.obstacle_color = [1, 0.5, 0]   # Оранжевый
            self.player_shape = 'triangle'
        elif theme == "relativity":
            self.player_color = [0, 1, 0]       # Зеленый
            self.obstacle_color = [1, 1, 0]     # Желтый
            self.player_shape = 'square'
        elif theme == "classic":
            self.player_color = [1, 0, 0]       # Красный
            self.obstacle_color = [0, 0, 1]     # Синий
            self.player_shape = 'circle'
        
        self.draw_all()

class PhysicsQuiz:
    def __init__(self):
        self.questions = [
            {
                "question": "Чему равно ускорение свободного падения на Земле? (м/с²)",
                "answer": "9.8",
                "theme": "classic"
            },
            {
                "question": "Какова скорость света в вакууме? (м/с)",
                "answer": "300000000",
                "theme": "relativity"
            },
            {
                "question": "Чему равна постоянная Планка? (×10⁻³⁴ Дж·с)",
                "answer": "6.626",
                "theme": "quantum"
            },
            {
                "question": "Формула второго закона Ньютона? (F = ?)",
                "answer": "ma",
                "theme": "classic"
            },
            {
                "question": "Формула энергии фотона? (E = h?/λ)",
                "answer": "c",
                "theme": "quantum"
            }
        ]
    
    def get_random_question(self):
        return random.choice(self.questions)

class MainScreen(BoxLayout):
    def __init__(self, **kwargs):
        super(MainScreen, self).__init__(**kwargs)
        self.orientation = 'horizontal'
        self.quiz = PhysicsQuiz()
        
        # Игровая область
        self.game_widget = GameWidget()
        self.add_widget(self.game_widget)
        
        # Панель с кнопкой
        side_panel = BoxLayout(orientation='vertical', size_hint=(0.2, 1))
        quiz_button = Button(text='Физическая задача', size_hint=(1, 0.1))
        quiz_button.bind(on_press=self.show_physics_quiz)
        side_panel.add_widget(quiz_button)
        
        # Добавляем подсказку управления
        controls_label = Label(text='Управление:\nW - вверх\nA - влево\nS - вниз\nD - вправо', 
                              size_hint=(1, 0.4))
        side_panel.add_widget(controls_label)
        
        self.add_widget(side_panel)
    
    def show_physics_quiz(self, instance):
        question_data = self.quiz.get_random_question()
        
        # Создаем popup с задачей
        content = BoxLayout(orientation='vertical', padding=10, spacing=10)
        content.add_widget(Label(text=question_data["question"]))
        
        answer_input = TextInput(hint_text='Введите ответ', multiline=False)
        content.add_widget(answer_input)
        
        button_layout = BoxLayout(size_hint_y=0.3, spacing=10)
        
        submit_btn = Button(text='Проверить')
        close_btn = Button(text='Закрыть')
        
        button_layout.add_widget(submit_btn)
        button_layout.add_widget(close_btn)
        content.add_widget(button_layout)
        
        popup = Popup(title='Физическая задача',
                     content=content,
                     size_hint=(0.8, 0.4))
        
        def check_answer(btn):
            user_answer = answer_input.text.strip().lower()
            correct_answer = question_data["answer"].lower()
            
            # Более гибкая проверка ответов
            if (user_answer == correct_answer or 
                user_answer.replace(',', '.') == correct_answer.replace(',', '.')):
                self.game_widget.change_theme(question_data["theme"])
                popup.dismiss()
                self.show_success_message()
            else:
                answer_input.background_color = (1, 0.7, 0.7, 1)  # Красный при ошибке
                Clock.schedule_once(lambda dt: setattr(answer_input, 'background_color', (1, 1, 1, 1)), 0.5)
        
        def close_popup(btn):
            popup.dismiss()
        
        def focus_input(instance, value):
            if value:
                answer_input.focus = True
        
        submit_btn.bind(on_press=check_answer)
        close_btn.bind(on_press=close_popup)
        popup.bind(on_open=focus_input)
        
        popup.open()
    
    def show_success_message(self):
        content = Label(text='Правильно! Внешний вид игры изменен!')
        popup = Popup(title='Успех!',
                     content=content,
                     size_hint=(0.6, 0.3))
        popup.open()
        Clock.schedule_once(lambda dt: popup.dismiss(), 1.5)

class PhysicsGameApp(App):
    def build(self):
        # Устанавливаем размер окна
        Window.size = (800, 600)
        return MainScreen()

if __name__ == '__main__':
    PhysicsGameApp().run()
